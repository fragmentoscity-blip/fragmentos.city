VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public key from your Wompi account. Use the sandbox key locally.
VITE_WOMPI_PUBLIC_KEY=

# Backend endpoint that returns the integrity signature for:
# { reference, amountInCents, currency }
# Expected JSON response: { "integrity": "sha256_hash" }
VITE_WOMPI_SIGNATURE_ENDPOINT=

# Optional. Wompi redirect URL after checkout.
VITE_WOMPI_REDIRECT_URL=http://localhost:3000

# Backend endpoint that sends the 6-digit registration code by email.
# Expected request JSON: { "email": "user@example.com", "code": "123456" }
VITE_REGISTRATION_CODE_ENDPOINT=/api/send-registration-code

# Server-only variables for api/send-registration-code.ts. Do not expose them with VITE_.
RESEND_API_KEY=
REGISTRATION_EMAIL_FROM=Fragmentos <registro@tu-dominio.com>
